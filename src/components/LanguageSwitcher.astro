---
import type { Locale, PageKey, TravelStory } from "../i18n/config";
import { localeList, localePath, travelStoryPath } from "../i18n/config";
import { locales } from "../i18n/config";

interface Props {
  locale: Locale;
  page: PageKey;
  travelStory?: TravelStory;
}

const { locale, page, travelStory } = Astro.props;

function pathForLocale(loc: Locale): string {
  if (page === "tours" && travelStory) return travelStoryPath(loc, travelStory);
  return localePath(loc, page);
}
---

<div class="lang-switcher">
  <label class="lang-label" for="lang-select">
    <span class="lang-globe" aria-hidden="true">🌐</span>
    <span class="sr-only">Language</span>
  </label>
  <select
    id="lang-select"
    class="lang-select"
    aria-label="Select language"
    onchange="if(this.value) window.location.assign(this.value)"
  >
    {localeList.map((loc) => (
      <option value={pathForLocale(loc)} selected={loc === locale}>
        {locales[loc].flag} {locales[loc].label}
      </option>
    ))}
  </select>
</div>

<style>
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .lang-label {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .lang-globe {
    font-size: 1.15rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .lang-select {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.4rem 0.6rem;
    font: inherit;
    background: white;
    color: var(--text);
    cursor: pointer;
    min-width: 0;
    width: min(10.5rem, 28vw);
    max-width: 100%;
  }
</style>
