---
import type { DiscoverContent } from "../i18n/discover-translations";
import type { ToursContent } from "../i18n/tours-translations";
import { tipsCardImage } from "../i18n/tours-translations";
import type { TravelStory } from "../i18n/config";

interface Props {
  tips: ToursContent;
  discover: DiscoverContent;
  backLabel: string;
  readTime: { tips: string; discover: string };
  indexPath: string;
  initialStory: TravelStory;
}

const { tips, discover, backLabel, readTime, indexPath, initialStory } = Astro.props;
---

<div class="travel-hub" data-initial-story={initialStory} data-index-path={indexPath}>
  <div
    class="travel-hub__panel"
    id="travel-panel-index"
    hidden={initialStory !== "index" ? true : undefined}
  >
    <div class="travel-posts">
      <a class="travel-post-card" href="#tips" data-story="tips">
        <div class="travel-post-card__image-wrap">
          <img
            src={tipsCardImage.src}
            alt={tipsCardImage.alt}
            loading="lazy"
            decoding="async"
            width="1200"
            height="720"
          />
        </div>
        <div class="travel-post-card__body">
          <h2 class="travel-post-card__title">{tips.title}</h2>
          <p class="travel-post-card__excerpt">{tips.intro}</p>
          <p class="travel-post-card__meta">{readTime.tips}</p>
        </div>
      </a>

      <a class="travel-post-card" href="#discover" data-story="discover">
        <div class="travel-post-card__image-wrap">
          <img
            src={discover.heroImage.src}
            alt={discover.heroImage.alt}
            loading="lazy"
            decoding="async"
            width="1400"
            height="605"
          />
        </div>
        <div class="travel-post-card__body">
          <h2 class="travel-post-card__title">{discover.title}</h2>
          <p class="travel-post-card__excerpt">{discover.intro}</p>
          <p class="travel-post-card__meta">{readTime.discover}</p>
        </div>
      </a>
    </div>
  </div>

  <div
    class="travel-hub__panel"
    id="travel-panel-tips"
    hidden={initialStory !== "tips" ? true : undefined}
  >
    <div class="travel-article-nav">
      <a class="travel-article-nav__back" href={indexPath}>{backLabel}</a>
    </div>
    <article class="blog-post blog-post--embedded">
      <div class="blog-post__inner">
        <header class="blog-post__header">
          <h1>{tips.title}</h1>
          <p class="blog-post__intro">{tips.intro}</p>
        </header>

        <section class="blog-post__section">
          <h2>{tips.recommendationsTitle}</h2>
          <ul class="travel-list">
            {tips.recommendations.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="blog-post__section">
          <h2>{tips.prohibitedTitle}</h2>
          <p>{tips.prohibitedIntro}</p>
          <ul class="travel-list">
            {tips.prohibited.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="blog-post__section">
          <h2>{tips.visaTitle}</h2>
          <p>{tips.visaIntro}</p>
          <ul class="travel-list">
            {tips.visaGroups.map((group) => (
              <li><strong>{group.label}</strong> {group.text}</li>
            ))}
          </ul>
          <p class="blog-post__note">{tips.visaNote}</p>
        </section>

        <section class="blog-post__section">
          <h2>{tips.emergencyTitle}</h2>
          <p>{tips.emergencyIntro}</p>
          <ul class="travel-list travel-list--contacts">
            {tips.emergency.map((contact) => (
              <li><strong>{contact.label}:</strong> <a href={`tel:${contact.number}`}>{contact.number}</a></li>
            ))}
          </ul>
        </section>
      </div>
    </article>
  </div>

  <div
    class="travel-hub__panel"
    id="travel-panel-discover"
    hidden={initialStory !== "discover" ? true : undefined}
  >
    <div class="travel-article-nav">
      <a class="travel-article-nav__back" href={indexPath}>{backLabel}</a>
    </div>
    <article class="blog-post blog-post--embedded">
      <div class="blog-post__inner">
        <header class="blog-post__header">
          <h1>{discover.title}</h1>
          <p class="blog-post__intro">{discover.intro}</p>
        </header>

        <figure class="blog-post__figure">
          <img
            src={discover.heroImage.src}
            alt={discover.heroImage.alt}
            loading="lazy"
            decoding="async"
            width="1400"
            height="605"
          />
        </figure>

        {discover.sections.map((section) => (
          <section class="blog-post__section">
            <h2>{section.title}</h2>
            {section.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </section>
        ))}

        <figure class="blog-post__figure">
          <img
            src={discover.landscapeImage.src}
            alt={discover.landscapeImage.alt}
            loading="lazy"
            decoding="async"
            width="1400"
            height="788"
          />
        </figure>

        <section class="blog-post__section blog-post__closing">
          <h2>{discover.closingTitle}</h2>
          {discover.closingParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          <p class="blog-post__question">{discover.closingQuestion}</p>
        </section>
      </div>
    </article>
  </div>
</div>

<script>
  type Story = "index" | "tips" | "discover";

  function activateTravelStory(story: Story, indexPath: string) {
    const hub = document.querySelector(".travel-hub");
    if (!hub) return;

    hub.querySelectorAll<HTMLElement>(".travel-hub__panel").forEach((panel) => {
      const isActive = panel.id === `travel-panel-${story}`;
      if (isActive) panel.removeAttribute("hidden");
      else panel.setAttribute("hidden", "");
    });

    const targetHash = story === "index" ? "" : `#${story}`;
    const indexUrl = new URL(indexPath, location.origin);
    const nextPath = indexUrl.pathname;
    const nextUrl = story === "index" ? indexPath : `${indexPath}${targetHash}`;

    if (location.pathname !== nextPath || location.hash !== (story === "index" ? "" : targetHash)) {
      history.replaceState(null, "", nextUrl);
    }

    if (story !== "index") {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  }

  function storyFromHash(): Story | null {
    if (location.hash === "#discover") return "discover";
    if (location.hash === "#tips") return "tips";
    return null;
  }

  function initTravelHub() {
    const hub = document.querySelector(".travel-hub");
    if (!hub) return;

    const indexPath = hub.getAttribute("data-index-path") ?? "/";
    const initial = storyFromHash() ?? (hub.getAttribute("data-initial-story") as Story) ?? "index";
    activateTravelStory(initial, indexPath);

    hub.querySelectorAll<HTMLAnchorElement>(".travel-post-card").forEach((card) => {
      card.addEventListener("click", (event) => {
        event.preventDefault();
        const story = card.dataset.story as Story;
        activateTravelStory(story, indexPath);
      });
    });

    hub.querySelectorAll<HTMLAnchorElement>(".travel-article-nav__back").forEach((link) => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        const indexUrl = new URL(indexPath, location.origin);
        if (location.pathname !== indexUrl.pathname) {
          window.location.assign(indexPath);
          return;
        }
        activateTravelStory("index", indexPath);
      });
    });

    window.addEventListener("hashchange", () => {
      const story = storyFromHash();
      if (story) activateTravelStory(story, indexPath);
      else if (location.pathname === new URL(indexPath, location.origin).pathname) {
        activateTravelStory("index", indexPath);
      }
    });
  }

  initTravelHub();
  document.addEventListener("astro:page-load", initTravelHub);
</script>

<style>
  .travel-posts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 3.5rem;
  }

  .travel-post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease;
  }

  .travel-post-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }

  .travel-post-card__image-wrap {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 5 / 3;
    background: var(--brand-pale);
  }

  .travel-post-card__image-wrap img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .travel-post-card__body {
    padding-top: 1rem;
  }

  .travel-post-card__title {
    font-size: 1.15rem;
    line-height: 1.35;
    margin: 0 0 0.75rem;
  }

  .travel-post-card__excerpt {
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .travel-post-card__meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
  }

  .travel-article-nav {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.25rem 1.25rem 0;
  }

  .travel-article-nav__back {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--brand);
    text-decoration: none;
  }

  .travel-article-nav__back:hover {
    text-decoration: underline;
  }

  .blog-post--embedded {
    padding-top: 0.5rem;
  }
</style>
