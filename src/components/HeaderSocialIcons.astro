---
import { business } from "../data/business";
import type { Locale } from "../i18n/config";
import { isChinaLocale } from "../i18n/china-translations";

interface Props {
  locale?: Locale;
}

const { locale } = Astro.props;

const googleGPaths = [
  { d: "M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z", fill: "#4285F4" },
  { d: "M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z", fill: "#34A853" },
  { d: "M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z", fill: "#FBBC05" },
  { d: "M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z", fill: "#EA4335" },
] as const;

const links = [
  ...(locale && isChinaLocale(locale)
    ? [{ href: business.china.xiaohongshu, label: "Xiaohongshu", icon: "xiaohongshu" as const }]
    : []),
  { href: business.social.facebook, label: "Facebook", icon: "facebook" as const },
  { href: business.social.tiktok, label: "TikTok", icon: "tiktok" as const },
  { href: business.social.youtube, label: "YouTube", icon: "youtube" as const },
  { href: business.mapsUrl, label: "Google Maps", icon: "google" as const },
];
---

<div class="header-social" aria-label="Social links">
  {links.map((link) => (
    <a
      class={`header-social-link header-social-link--${link.icon}`}
      href={link.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={link.label}
      title={link.label}
    >
      {link.icon === "xiaohongshu" && (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.2 5.2c1.66 0 3 1.34 3 3s-1.34 3-3 3-1.66 0-3-1.34-3-3 0-1.66 1.34-3 3-3zm-4.8 0c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm7.2 0c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zM8.4 16.8c1.55-1.2 3.35-1.8 5.2-1.8s3.65.6 5.2 1.8l-1.2 1.6c-1.15-.85-2.5-1.3-4-1.3s-2.85.45-4 1.3l-1.2-1.6z" />
        </svg>
      )}
      {link.icon === "facebook" && (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
        </svg>
      )}
      {link.icon === "tiktok" && (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
        </svg>
      )}
      {link.icon === "youtube" && (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
        </svg>
      )}
      {link.icon === "google" && (
        <span class="header-social-google-wrap">
          <svg
            class="header-social-google header-social-google--mono"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="currentColor"
            aria-hidden="true"
          >
            {googleGPaths.map(({ d }) => <path d={d} />)}
          </svg>
          <svg
            class="header-social-google header-social-google--color"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            aria-hidden="true"
          >
            {googleGPaths.map(({ d, fill }) => <path fill={fill} d={d} />)}
          </svg>
        </span>
      )}
    </a>
  ))}
</div>

<style>
  .header-social {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .header-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--brand-pale);
    color: var(--brand);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }

  .header-social-link:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .header-social-link--xiaohongshu:hover {
    background: #ff2442;
    color: white;
  }

  .header-social-link--facebook:hover {
    background: #1877f2;
    color: white;
  }

  .header-social-link--tiktok:hover {
    background: #010101;
    color: white;
  }

  .header-social-link--youtube:hover {
    background: #ff0000;
    color: white;
  }

  .header-social-google-wrap {
    position: relative;
    display: grid;
    place-items: center;
    width: 18px;
    height: 18px;
  }

  .header-social-google {
    grid-area: 1 / 1;
    display: block;
    shape-rendering: geometricPrecision;
    transition: opacity 0.2s ease;
  }

  .header-social-google--color {
    opacity: 0;
  }

  .header-social-link--google:hover {
    background: #fff;
    box-shadow: 0 2px 10px rgba(13, 43, 69, 0.14);
  }

  .header-social-link--google:hover .header-social-google--mono {
    opacity: 0;
  }

  .header-social-link--google:hover .header-social-google--color {
    opacity: 1;
  }
</style>
