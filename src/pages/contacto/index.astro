---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Replace with your Formspree endpoint after signup: https://formspree.io
const formAction = "https://formspree.io/f/your-form-id";
---

<BaseLayout title="Contacto | Conexión Bolivia Visas">
  <section class="hero">
    <div class="container">
      <div class="panel">
        <p class="eyebrow">Contacto</p>
        <h1>Contáctanos</h1>
        <p class="lead">Estamos aquí para ayudarte con tu visa a Bolivia.</p>

        <form class="form" method="POST" action={formAction}>
          <label>
            Nombre completo
            <input type="text" name="name" required />
          </label>
          <label>
            Correo electrónico
            <input type="email" name="email" required />
          </label>
          <label>
            Mensaje
            <textarea name="message" required></textarea>
          </label>
          <button class="button button-primary" type="submit">Enviar consulta</button>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-3">
      <article class="card">
        <h3>Ubicación</h3>
        <p>Urbanización Magisterio, Cusco — frente al Consulado de Bolivia.</p>
      </article>
      <article class="card">
        <h3>Horario</h3>
        <p>Lunes a viernes, 8:00 a 19:00. Sábados y domingos solo emergencias con cita previa.</p>
      </article>
      <article class="card">
        <h3>WhatsApp</h3>
        <p>
          <a href="https://wa.me/51977235501" target="_blank" rel="noopener noreferrer">
            Escríbenos por WhatsApp
          </a>
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
